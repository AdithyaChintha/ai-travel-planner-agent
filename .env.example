# Copy this file to ".env" and fill in your real values.
# Never commit the real ".env" file to git.

# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Get a free key at https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Gmail account used to SEND alert emails.
# GMAIL_APP_PASSWORD must be a 16-character "App Password", NOT your normal
# Gmail password. Generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account).
GMAIL_ADDRESS=youraccount@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# --- Optional overrides (defaults shown) ---
# GEMINI_MODEL=gemini-2.5-flash
# TAVILY_MAX_RESULTS=3
# BUDGET_MAX_RETRIES=2
# DISRUPTION_CHECK_INTERVAL_DAYS=4
# API_HOST=127.0.0.1
# API_PORT=8000
